{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information including 2FA settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "countryCode": { "type": "string" },
        "profilePicture": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "lastBadge": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "mobileNumber", "countryCode"]
    },
    "Entry": {
      "title": "Competition Entry",
      "description": "A daily entry for the competition.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["fruit", "vegetable", "math", "prayer", "tictactoe", "kindness"] },
        "points": { "type": "number" },
        "content": { "type": "string" },
        "solution": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "weekId": { "type": "string" },
        "dayId": { "type": "string" }
      },
      "required": ["userId", "type", "points", "weekId", "dayId"]
    },
    "Leaderboard": {
      "title": "Weekly Leaderboard",
      "description": "Summary of points for a specific week.",
      "type": "object",
      "properties": {
        "weekId": { "type": "string" },
        "scores": {
          "type": "object",
          "description": "Map of userId to points"
        },
        "winnerId": { "type": "string" },
        "winnerBadge": { "type": "string" },
        "availableBadges": { "type": "array", "items": { "type": "string" } },
        "isFinalized": { "type": "boolean" }
      },
      "required": ["weekId", "scores"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A text message sent between users or to the group.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "type": { "type": "string", "enum": ["group", "direct"] },
        "text": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["senderId", "type", "text", "senderName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Daily competition entries"
    },
    "/leaderboards/{weekId}": {
      "schema": "Leaderboard",
      "description": "Weekly leaderboard summaries"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    }
  }
}
